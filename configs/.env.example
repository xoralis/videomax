# videoMax 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# 服务端口
SERVER_PORT=8080

# MySQL 数据库连接
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/videomax?charset=utf8mb4&parseTime=True&loc=Local

# Kafka 配置
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=video-tasks

# OpenAI API
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# 视频生成服务商配置
VIDEO_PROVIDER=bytedance
VIDEO_API_KEY=xxxx
VIDEO_API_BASE_URL=https://api.example.com
